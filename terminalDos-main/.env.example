# =============================
# 🌊 TERMINAL DOS - CONFIGURACIÓN
# =============================

# Servidor
PORT=3000
NODE_ENV=development

# Base de Datos (cuando esté lista)
DB_HOST=localhost
DB_USER=terminal_user
DB_PASSWORD=terminal_password_123
DB_NAME=terminal_dos_db
DB_PORT=3306

# APIs Externas
WEATHER_API_KEY=tu_api_key_clima_aqui
OPENWEATHER_API_KEY=
AIS_API_KEY=

# Configuración de Aplicación
APP_NAME="Terminal Dos Dashboard"
APP_VERSION=1.0.0
APP_URL=http://localhost:3000

# Seguridad
SESSION_SECRET=terminal_dos_super_secret_key_2024
JWT_SECRET=jwt_secret_terminal_dos

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/terminal-dos.log

# CORS - Dominios permitidos
ALLOWED_ORIGINS=http://localhost:3000,https://terminal-lapaz.mx

# Configuración de Cache
CACHE_TTL=300
REDIS_URL=redis://localhost:6379

# Notificaciones
EMAIL_SERVICE=gmail
EMAIL_USER=notifications@terminal-dos.mx
EMAIL_PASSWORD=
WEBHOOK_URL=
